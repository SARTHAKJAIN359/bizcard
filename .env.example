# Copy to .env and fill values

# Groq (optional; if unset, app falls back to heuristic extraction)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT_SEC=15

# Tesseract
# Windows examples:
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR
TESSERACT_CMD=
TESSERACT_LANG=eng
TESSERACT_TIMEOUT_SEC=6

# OCR tuning
OCR_MAX_VARIANTS=4
OCR_TIME_BUDGET_SEC=10
OCR_ENABLE_HOMOMORPHIC_DFT=1
OCR_ENABLE_ORIENTATION_VARIANTS=1

# Database (optional)
DATABASE_URL=sqlite:///knowledge_base.db

