# Groq API key for business card data extraction
GROQ_API_KEY=

# Groq model (optional, defaults to llama-3.1-8b-instant)
GROQ_MODEL=llama-3.1-8b-instant

# Tesseract OCR path (optional)
# Example: C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=

# Database URL (optional, defaults to local SQLite)
# For Render PostgreSQL: postgresql://user:password@host:port/database
# For local testing: sqlite:///knowledge_base.db
DATABASE_URL=
